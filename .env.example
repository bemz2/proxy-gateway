APP_NAME=Proxy Gateway API
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://proxy_user:proxy_password@postgres:5432/proxy_gateway
TEST_DATABASE_URL=postgresql+psycopg2://proxy_user:proxy_password@localhost:5432/proxy_gateway_test
REDIS_URL=redis://redis:6379/0
SECRET_KEY=super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ACTIVATION_KEY_LENGTH=32
ACTIVATION_KEY_TTL_HOURS=24
USE_CONSOLE_EMAIL=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password_here
SMTP_SENDER=noreply@example.com
WS_HEARTBEAT_SECONDS=10
VM_ALLOCATION_TIMEOUT_HOURS=24
